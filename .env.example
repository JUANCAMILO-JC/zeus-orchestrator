# Anthropic API key — obtenla en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-REEMPLAZA-CON-TU-KEY

# Modelo a usar para todos los agentes (opcional, default: claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8

# Puerto del servidor
PORT=3000

# API key propia del orquestador (opcional en local, OBLIGATORIA antes de
# exponer el server fuera de localhost). Si está definida, todo endpoint
# salvo /orchestrate/health exige el header `x-api-key: <key>` (o
# `Authorization: Bearer <key>`). El CLI la lee de ZEUS_API_KEY.
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ZEUS_API_KEY=
